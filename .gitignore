# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.env
.venv
venv/
*.egg

# User config (contains personal paths)
config/config.json

# Runtime data
data/logs/*
data/output/*
!data/logs/.gitkeep
!data/output/.gitkeep

# Working test input (consumed by scrub - re-copy from test_data/before_and_after before each run)
data/input/*
!data/input/.gitkeep

# Test data - never committed. before_and_after is the gold standard, NEVER point config at it
/data/test_data
/data/test_data_backup

# Auto-downloaded binaries (re-downloaded on first run)
dependencies/ffmpeg/*.exe
dependencies/flac/*.exe

# IDE
.idea/
.vscode/
*.suo
*.user

# OS
.DS_Store
Thumbs.db
desktop.ini