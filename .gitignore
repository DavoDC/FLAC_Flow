# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
dist/
build/
.env
.venv
venv/
*.egg

# User config (contains personal paths)
config/config.json

# Runtime data
data/logs/*
data/output/*
!data/logs/.gitkeep
!data/output/.gitkeep

# Auto-downloaded binaries (re-downloaded on first run)
dependencies/ffmpeg/*.exe
dependencies/flac/*.exe

# IDE
.idea/
.vscode/
*.suo
*.user

# OS
.DS_Store
Thumbs.db
desktop.ini
